{
  "build": {
    "builder": "nixpacks",
    "nixpacksConfig": {
      "phases": {
        "setup": {
          "nixPkgs": ["php81", "composer"]
        }
      }
    },
    "buildCommand": "cd becraft && composer install --no-dev --optimize-autoloader"
  },
  "deploy": {
    "startCommand": "php -S 0.0.0.0:$PORT -t becraft/public"
  }
}
